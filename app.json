{
  "expo": {
    "name": "拾光",
    "slug": "lucid-app",
    "version": "1.0.0",
    "scheme": "lucid",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.frankzhao.shiguang",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "用于在设备本地把语音识别成文字。",
        "NSMicrophoneUsageDescription": "用于录下你的语音并转成文字记录。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "用于从相册选择照片，添加到你的感悟卡片。"
        }
      ],
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "用于录下你的语音并转成文字记录。",
          "speechRecognitionPermission": "用于在设备本地把语音识别成文字。"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "37200a60-07b0-4f74-bfb1-8bd88793d111"
      }
    },
    "owner": "zyq1999"
  }
}
